# --- セキュリティ (絶対に必要) ---
# 認証キー
gcp-key.json

# --- Go 関連 ---
# ビルドで生成される実行ファイル
app
main
*.exe
*.test
.env

# 依存関係（通常は go.mod/sum があれば不要）
# Goのツール
vendor/

# --- システム/エディタ (環境を汚さない) ---
.vscode/
.idea/
.DS_Store
Thumbs.db

# --- Terraform 関連 (機密情報とバイナリ) ---
# プラグインなどの実行バイナリ
.terraform/

# インフラの現在の状態（State）
# これを上げると他の人が実行した時に競合したり、機密が漏れたりします
*.tfstate
*.tfstate.*

# 依存関係のロックファイル（チーム開発でなければ無視してOK）
.terraform.lock.hcl
